91:def referee_triple(a_gene: str, c_disease: str, condition: str, data,
92:                   b_program: str = "Th1_Th2_polarization") -> dict:
93:    """Answer one LBD triple (A gene, B program, C disease, condition) on the exact C.
94:
95:    Returns a dict with the base hops (HOP-3 replaced by the exact-C hop), a re-synthesized
96:    `overall`, and `answer` in {supported, refuted_for_c, untested}. `untested` means the
97:    knockdown gate failed (the hero QC catch) -> the question is unanswerable here.
98:    """
99:    v = _REF.referee(a_gene, condition, data)          # HOP-0/1/2 + generic HOP-3
100:    base = {"a_gene": a_gene, "b_program": b_program, "c_disease": c_disease,
101:            "condition": condition, "resolved_symbol": v.gene_symbol, "gate_pass": v.gate_pass}
102:
103:    if not v.gate_pass:                                 # HOP-0 failed -> untested (hero catch)
104:        return {**base, "answer": "untested",
105:                "overall": "untested - knockdown failed QC gate",
106:                "hops": [h.__dict__ for h in v.hops]}
107:
108:    # swap generic HOP-3 for exact-C HOP-3, then re-synthesize overall from it
109:    c_hop, classification = _hop3_for_disease(data, v.gene_symbol, condition, c_disease)
110:    v.hops = [h for h in v.hops if h.name != "DISEASE"] + [c_hop]
111:    v.hops.sort(key=lambda h: h.hop)
112:    overall = _REF._synthesize_overall(v)
113:
114:    answer = "supported" if classification == "supported" else \
115:             ("untested" if classification == "untested_for_c" else "refuted_for_c")

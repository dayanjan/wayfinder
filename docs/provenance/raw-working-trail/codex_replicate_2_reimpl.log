"C:\\Program Files\\PowerShell\\7\\pwsh.exe" -Command "@'
import pandas as pd
import ast
from collections import Counter, defaultdict

T4 = pd.read_csv('data/guide_kd_efficiency.suppl_table.csv')
T1 = pd.read_csv('data/DE_stats.suppl_table.csv')
T2 = pd.read_csv('data/Th2_Th1_polarization_signature_DE_results_full.suppl_table.csv')
T3 = pd.read_csv('data/cluster_autoimmune_enrichment_results.suppl_table.csv')

cond='Stim8hr'
alpha=0.05

# symbol -> ENSG map from T1
stim_t1 = T1[T1['culture_condition'].eq(cond)].copy()
sym_to_ensg = (stim_t1[['target_contrast_gene_name','target_contrast']]
               .dropna().drop_duplicates().set_index('target_contrast_gene_name')['target_contrast'].to_dict())
ensg_to_sym = (stim_t1[['target_contrast_gene_name','target_contrast']]
               .dropna().drop_duplicates().set_index('target_contrast')['target_contrast_gene_name'].to_dict())

nab2_ensg = sym_to_ensg['NAB2']
print('NAB2 ENSG', nab2_ensg)

# A1 Gate
nab2_t4 = T4[(T4['culture_condition'].eq(cond)) & (T4['perturbed_gene_id'].eq(nab2_ensg))].copy()
print('\\nA1 NAB2 T4 rows')
print(nab2_t4[['Unnamed: 0','signif_knockdown','adj_p_value','guide_mean_expr','ntc_mean_expr']].to_string(index=False))
print('A1 summary', {
    'n_guides': int(len(nab2_t4)),
    'n_signif': int(nab2_t4['signif_knockdown'].fillna(False).astype(bool).sum()),
    'best_adj_p': float(nab2_t4['adj_p_value'].min()),
    'mean_guide_expr': float(nab2_t4['guide_mean_expr'].mean()),
    'mean_ntc_expr': float(nab2_t4['ntc_mean_expr'].mean()),
})

# A2 Effect
nab2_t1 = stim_t1[stim_t1['target_contrast_gene_name'].eq('NAB2')].copy()
print('\\nA2 NAB2 T1')
print(nab2_t1[['target_contrast_gene_name','target_contrast','ontarget_significant','ontarget_effect_size','n_downstream','offtarget_flag']].to_string(index=False))

# A3 Program
nab2_t2 = T2[T2['variable'].eq('NAB2')].copy()
print('\\nA3 NAB2 T2')
print(nab2_t2[['contrast','log_fc','zscore','adj_p_value']].to_string(index=False))

# A4 Disease: parse exact rows where NAB2 intersects
stim_gene_set = f'downstream_{cond}'
t3_stim = T3[T3['gene_set'].eq(stim_gene_set)].copy()
# parse lists once

def parse_genes(x):
    if pd.isna(x): return []
    return ast.literal_eval(x)

t3_stim['genes_list'] = t3_stim['intersecting_genes'].map(parse_genes)
nab2_disease = t3_stim[(t3_stim['disease'].eq('atopic eczema')) & (t3_stim['genes_list'].map(lambda xs: 'NAB2' in xs))]
print('\\nA4 NAB2 atopic eczema T3 rows')
print(nab2_disease[['cluster','disease','gene_set','odds_ratio','p_adj_fdr','intersecting_genes']].to_string(index=False))
print('A4 any_fdr_lt_0.05', bool((nab2_disease['p_adj_fdr'] < alpha).any()))

# Build independent classifier inputs
# KD gate: >=1 signif guide at Stim8hr
stim_t4 = T4[T4['culture_condition'].eq(cond)].copy()
kd_by_ensg = stim_t4.groupby('perturbed_gene_id')['signif_knockdown'].apply(lambda s: bool(s.fillna(False).astype(bool).any()))
kd_symbols = {ensg_to_sym[e] for e, ok in kd_by_ensg.items() if ok and e in ensg_to_sym}

# effect rows by symbol. Use one row per gene for Stim8hr (assert duplicates if any)
dup_effect = stim_t1['target_contrast_gene_name'].value_counts()
print('\\nDuplicate T1 Stim8hr genes >1:', int((dup_effect>1).sum()))
effect_by_gene = {}
for _, r in stim_t1.dropna(subset=['target_contrast_gene_name']).iterrows():
    g = r['target_contrast_gene_name']
    effect_by_gene[g] = {
        'ontarget_significant': bool(r['ontarget_significant']),
        'ontarget_effect_size': float(r['ontarget_effect_size']) if pd.notna(r['ontarget_effect_size']) else None,
        'n_downstream': int(r['n_downstream']) if pd.notna(r['n_downstream']) else 0,
        'offtarget_flag': bool(r['offtarget_flag']),
        'effect_pass': bool(r['ontarget_significant']) or (pd.notna(r['n_downstream']) and int(r['n_downstream']) > 0),
    }
effect_symbols = {g for g, v in effect_by_gene.items() if v['effect_pass']}

# program significant: any T2 contrast adj_p<0.05
program_by_gene = T2.groupby('variable')['adj_p_value'].apply(lambda s: bool((s < alpha).any())).to_dict()
program_symbols = {g for g, ok in program_by_gene.items() if ok}

A = sorted(kd_symbols & effect_symbols & program_symbols)
print('\\nA universe counts', {
    'kd_gate_symbols': len(kd_symbols),
    'effect_symbols': len(effect_symbols),
    'program_symbols': len(program_symbols),
    'A_intersection': len(A),
    'NAB2_in_A': 'NAB2' in A,
})

# Diseases: T3 diseases excluding umbrella terms
umbrella = {'autoimmune disease','inflammatory bowel disease'}
diseases = sorted(d for d in t3_stim['disease'].dropna().unique() if d not in umbrella)
print('Eligible diseases', len(diseases), diseases)

# Build disease support lookup by exact disease where gene in intersecting_genes and p_adj_fdr<0.05
support_rows = defaultdict(list)
for _, r in t3_stim.iterrows():
    d = r['disease']
    if d in umbrella:
        continue
    sig = bool(r['p_adj_fdr'] < alpha)
    for g in r['genes_list']:
        support_rows[(g,d)].append({
            'cluster': int(r['cluster']),
            'p_adj_fdr': float(r['p_adj_fdr']),
            'odds_ratio': float(r['odds_ratio']),
            'sig': sig,
        })

def classify(g, d, condition=cond):
    # raw-data classifier with deterministic gates
    if g not in sym_to_ensg:
        return 'untested'
    ensg = sym_to_ensg[g]
    if not bool(kd_by_ensg.get(ensg, False)):
        return 'untested'
    ev = effect_by_gene.get(g)
    if ev is None or not ev['effect_pass']:
        return 'refuted_effect'
    if not bool(program_by_gene.get(g, False)):
        return 'refuted_program'
    rows = support_rows.get((g,d), [])
    disease_ok = any(r['sig'] for r in rows)
    if not disease_ok:
        return 'refuted_for_c'
    if ev['offtarget_flag']:
        return 'supported_flagged'
    if ev['n_downstream'] == 0:
        return 'supported_weak'
    return 'supported'

counts = Counter()
by_gene_supported = defaultdict(list)
for g in A:
    for d in diseases:
        c = classify(g,d)
        counts[c] += 1
        if c.startswith('supported'):
            by_gene_supported[g].append((d,c))
print('\\nB3 classifier counts over A x 12')
print(dict(counts))
print('supported_total', sum(v for k,v in counts.items() if k.startswith('supported')))
print('clean weak flagged', counts['supported'], counts['supported_weak'], counts['supported_flagged'])
print('NAB2 supported diseases', by_gene_supported.get('NAB2'))

# additional: status of NAB2 x atopic eczema
print('NAB2_atopic_classifier', classify('NAB2','atopic eczema'))

# proportions among disease-supported
sup_total=sum(v for k,v in counts.items() if k.startswith('supported'))
if sup_total:
    print('supported proportions', {k: counts[k]/sup_total for k in ['supported','supported_weak','supported_flagged']})

# Genes with supported counts maybe inspect flagged/weak examples and refuted_effect sanity
print('number genes with >=1 disease support', len(by_gene_supported))
print('top supported genes', sorted(((g,len(v),v[:5]) for g,v in by_gene_supported.items()), key=lambda x: (-x[1], x[0]))[:10])

# Check if any non-A gene disease-supported but classifier refuted_effect among all KD+program? optional candidate-free sanity
all_symbols = sorted((set(sym_to_ensg) & set(program_by_gene)))
all_counts = Counter(classify(g,d) for g in all_symbols for d in diseases)
print('\\nAll mapped program symbols x 12 counts (context)', dict(all_counts))

# STAT6 / adjacency simple data presence and T2 z check
print('\\nSTAT6 T2')
print(T2[T2['variable'].eq('STAT6')][['contrast','log_fc','zscore','adj_p_value']].to_string(index=False))
print('STAT6 supported diseases', [(d, classify('STAT6', d)) for d in diseases if classify('STAT6', d).startswith('supported')])

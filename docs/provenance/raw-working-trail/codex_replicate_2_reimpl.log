import pandas as pd, ast
from collections import Counter, defaultdict
T4=pd.read_csv('data/guide_kd_efficiency.suppl_table.csv')
T1=pd.read_csv('data/DE_stats.suppl_table.csv')
T2=pd.read_csv('data/Th2_Th1_polarization_signature_DE_results_full.suppl_table.csv')
T3=pd.read_csv('data/cluster_autoimmune_enrichment_results.suppl_table.csv')
cond='Stim8hr'; alpha=0.05
stim_t1=T1[T1.culture_condition.eq(cond)]
sym_to_ensg=stim_t1[['target_contrast_gene_name','target_contrast']].dropna().drop_duplicates().set_index('target_contrast_gene_name')['target_contrast'].to_dict()
ensg_to_sym=stim_t1[['target_contrast_gene_name','target_contrast']].dropna().drop_duplicates().set_index('target_contrast')['target_contrast_gene_name'].to_dict()
stim_t4=T4[T4.culture_condition.eq(cond)]
kd_by_ensg=stim_t4.groupby('perturbed_gene_id')['signif_knockdown'].apply(lambda s: bool(s.fillna(False).astype(bool).any()))
kd_symbols={ensg_to_sym[e] for e, ok in kd_by_ensg.items() if ok and e in ensg_to_sym}
effect_by_gene={}
for _,r in stim_t1.dropna(subset=['target_contrast_gene_name']).iterrows():
    nd=int(r.n_downstream) if pd.notna(r.n_downstream) else 0
    effect_by_gene[r.target_contrast_gene_name]={'ontarget_significant':bool(r.ontarget_significant),'n_downstream':nd,'offtarget_flag':bool(r.offtarget_flag),'effect_pass':bool(r.ontarget_significant) or nd>0}
effect_symbols={g for g,v in effect_by_gene.items() if v['effect_pass']}
program_by_gene=T2.groupby('variable')['adj_p_value'].apply(lambda s: bool((s<alpha).any())).to_dict()
program_symbols={g for g,ok in program_by_gene.items() if ok}
A=sorted(kd_symbols & effect_symbols & program_symbols)
t3=T3[T3.gene_set.eq(f'downstream_{cond}')].copy()
t3['genes_list']=t3.intersecting_genes.map(lambda x: ast.literal_eval(x) if pd.notna(x) else [])
umbrella={'autoimmune disease','inflammatory bowel disease'}
d12=sorted(d for d in t3.loc[~t3.negative_control_disease,'disease'].dropna().unique() if d not in umbrella)
d15=sorted(d for d in t3['disease'].dropna().unique() if d not in umbrella)

def make_support(disease_set):
    support=defaultdict(list)
    for _,r in t3[t3.disease.isin(disease_set)].iterrows():
        for g in r.genes_list:
            support[(g,r.disease)].append((int(r.cluster),float(r.odds_ratio),float(r.p_adj_fdr),bool(r.p_adj_fdr<alpha)))
    return support

def counts_for(diseases):
    support=make_support(set(diseases))
    def classify(g,d):
        if g not in sym_to_ensg: return 'untested'
        if not bool(kd_by_ensg.get(sym_to_ensg[g],False)): return 'untested'
        ev=effect_by_gene.get(g)
        if ev is None or not ev['effect_pass']: return 'refuted_effect'
        if not bool(program_by_gene.get(g,False)): return 'refuted_program'
        if not any(x[3] for x in support.get((g,d),[])): return 'refuted_for_c'
        if ev['offtarget_flag']: return 'supported_flagged'
        if ev['n_downstream']==0: return 'supported_weak'
        return 'supported'
    c=Counter(); by=defaultdict(list)
    for g in A:
        for d in diseases:
            s=classify(g,d); c[s]+=1
            if s.startswith('supported'): by[g].append((d,s))
    return c,by, classify

for name, diseases in [('12_nonneg_nonumbrella',d12),('15_nonumbrella_including_negctrl',d15)]:
    c, by, classify = counts_for(diseases)
    print('\\n', name, len(diseases), diseases)
    print('pairs', len(A)*len(diseases))
    print(dict(c))
    print('supported_total', sum(v for k,v in c.items() if k.startswith('supported')))
    print('clean weak flagged', c['supported'], c['supported_weak'], c['supported_flagged'])
    print('NAB2', by.get('NAB2'))
    print('NAB2 atopic', classify('NAB2','atopic eczema') if 'atopic eczema' in diseases else None)
    total=sum(v for k,v in c.items() if k.startswith('supported'))
    print('props', {k: (c[k]/total if total else None) for k in ['supported','supported_weak','supported_flagged']})

# disease support exact rows for NAB2 in d12 including nonsig rows
nab2_rows=t3[(t3.disease.eq('atopic eczema')) & (t3.genes_list.map(lambda xs:'NAB2' in xs))]
print('\\nNAB2 atopic rows compact')
print(nab2_rows[['cluster','odds_ratio','p_adj_fdr']].sort_values('p_adj_fdr').to_string(index=False))

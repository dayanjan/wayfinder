    1: """
    2: PyzoBot Hypothesis-Referee (the Validator)
    3: ==========================================
    4: 
    5: Traces one CD4+ T-cell gene through a 4-table Perturb-seq evidence chain and
    6: returns a STRUCTURED VERDICT in which every status is backed by an explicit
    7: data receipt. Join contract is read from `pyzobot_join_spec.json`.
    8: 
    9: Chain:
   10:   HOP 0  knockdown-QC GATE (T4)  -- is the perturbation valid at all?
   11:   HOP 1  gene -> EFFECT (T1)     -- on-target KD + downstream effect
   12:   HOP 2  effect -> PROGRAM (T2)  -- Th1/Th2 shift, faceted by contrast
   13:   HOP 3  program -> DISEASE (T3) -- membership in disease-enriched clusters
   14: 
   15: Calibrated status vocabulary ONLY (never "proven"/"discovered"):
   16:   supported   -- a receipt in the tables is consistent with the claim
   17:   refuted     -- a receipt in the tables contradicts the claim
   18:   untested    -- the perturbation is invalid/absent; claim cannot be evaluated
   19:   flagged     -- a caveat (off-target, low reproducibility, missing mapping)
   20: 
   21: Design rule (the hero feature): HOP 0 runs FIRST. If the knockdown failed,
   22: downstream nulls are UNTESTED, never "no effect".
   23: """
   24: from __future__ import annotations
   25: import os, ast, json
   26: from dataclasses import dataclass, field, asdict
   27: from typing import Optional
   28: import pandas as pd
   29: import numpy as np
   30: 
   31: # ----------------------------------------------------------------------------- config
   32: DEFAULT_DATA_DIR = "/home/dayanjan/pyzobot-data"
   33: DEFAULT_SPEC     = "pyzobot_join_spec.json"
   34: CONDITIONS       = ("Rest", "Stim8hr", "Stim48hr")
   35: SIG_ALPHA        = 0.05   # adj-p / FDR threshold used throughout
   36: 
   37: 
   38: # ----------------------------------------------------------------------------- data holder
   39: class RefereeData:
   40:     """Loads and pre-indexes the four tables once, per the join spec."""
   41: 
   42:     def __init__(self, data_dir: str = DEFAULT_DATA_DIR, spec_path: str = DEFAULT_SPEC):
   43:         self.spec = json.load(open(spec_path))
   44:         f = {k: v["file"] for k, v in self.spec["tables"].items()}
   45:         self.t1 = pd.read_csv(os.path.join(data_dir, f["T1_DE_stats"]))
   46:         self.t2 = pd.read_csv(os.path.join(data_dir, f["T2_Th2_Th1"]))
   47:         self.t3 = pd.read_csv(os.path.join(data_dir, f["T3_cluster_enrichment"]))
   48:         self.t4 = pd.read_csv(os.path.join(data_dir, f["T4_guide_kd"]))
   49: 
   50:         # ENSG <-> SYMBOL (T1 is 1:1 and carries both)
   51:         self.sym2ens = dict(zip(self.t1.target_contrast_gene_name, self.t1.target_contrast))
   52:         self.ens2sym = {v: k for k, v in self.sym2ens.items()}
   53: 
   54:         # HOP 0 gate: aggregate guides -> gene x condition (spec join "gate")
   55:         t4v = self.t4.dropna(subset=["perturbed_gene_id"])
   56:         self.gate = (t4v.groupby(["perturbed_gene_id", "culture_condition"])
   57:                         .agg(n_guides=("signif_knockdown", "size"),
   58:                              n_signif=("signif_knockdown", "sum"),
   59:                              best_adj_p=("adj_p_value", "min"),
   60:                              mean_guide_expr=("guide_mean_expr", "mean"),
   61:                              mean_ntc_expr=("ntc_mean_expr", "mean"))
   62:                         .reset_index())
   63:         self.gate["gate_pass"] = self.gate.n_signif > 0
   64: 
   65:         # HOP 3: explode T3 intersecting_genes (real diseases only), keep neg-controls aside
   66:         self.t3_real = self.t3[~self.t3.negative_control_disease].copy()
   67:         rows = []
   68:         for _, r in self.t3_real.iterrows():
   69:             for g in self._parse_list(r.intersecting_genes):
   70:                 rows.append((g, r.cluster, r.disease, r.gene_set,
   71:                              r.odds_ratio, r.p_adj_fdr, r.cluster_size))
   72:         self.t3_exploded = pd.DataFrame(
   73:             rows, columns=["gene", "cluster", "disease", "gene_set",
   74:                            "odds_ratio", "p_adj_fdr", "cluster_size"])
   75: 
   76:     @staticmethod
   77:     def _parse_list(s):
   78:         try:
   79:             return ast.literal_eval(s) if isinstance(s, str) else []
   80:         except (ValueError, SyntaxError):
   81:             return []
   82: 
   83:     def resolve(self, gene: str):
   84:         """Accept a SYMBOL or an ENSG; return (symbol, ensg) or (None, None)."""
   85:         if gene in self.sym2ens:
   86:             return gene, self.sym2ens[gene]
   87:         if gene in self.ens2sym:
   88:             return self.ens2sym[gene], gene
   89:         # tolerate ENSG with version suffix
   90:         base = gene.split(".")[0]
   91:         if base in self.ens2sym:
   92:             return self.ens2sym[base], base
   93:         return None, None

root=Path(r'C:\\Users\\wijesingheds\\Documents\\04 Fun with Coding\\2026-07-07 PyZoBot-Arbiter')
data=root/'data'
# A universe independent per entities.py
t4=pd.read_csv(data/'guide_kd_efficiency.suppl_table.csv', usecols=['perturbed_gene_id','culture_condition','signif_knockdown','adj_p_value','guide_mean_expr','ntc_mean_expr'])
t1=pd.read_csv(data/'DE_stats.suppl_table.csv', usecols=['target_contrast','target_contrast_gene_name','culture_condition','ontarget_significant','ontarget_effect_size','n_downstream','offtarget_flag'])
t2=pd.read_csv(data/'Th2_Th1_polarization_signature_DE_results_full.suppl_table.csv')
t4['signif_knockdown']=t4['signif_knockdown'].astype(str).str.lower().eq('true')
t1['ontarget_significant']=t1['ontarget_significant'].astype(str).str.lower().eq('true')
t1['offtarget_flag']=t1['offtarget_flag'].astype(str).str.lower().eq('true')
t1['n_downstream']=pd.to_numeric(t1['n_downstream'], errors='coerce').fillna(0)
t2['adj_p_value']=pd.to_numeric(t2['adj_p_value'], errors='coerce')
gate=t4.dropna(subset=['perturbed_gene_id']).groupby(['perturbed_gene_id','culture_condition'])['signif_knockdown'].any().reset_index()
gate=gate[gate.signif_knockdown].rename(columns={'perturbed_gene_id':'ensg','culture_condition':'condition'})
effect=t1[t1.ontarget_significant | (t1.n_downstream>0)].rename(columns={'target_contrast':'ensg','target_contrast_gene_name':'symbol','culture_condition':'condition'})
effect=effect.groupby(['ensg','symbol','condition'])['n_downstream'].max().reset_index()
a=gate.merge(effect,on=['ensg','condition'])[['ensg','symbol','condition','n_downstream']].drop_duplicates()
prog=set(t2.loc[t2.adj_p_value<0.05,'variable'].dropna().unique())
ap=a[a.symbol.isin(prog)]
print('A all rows',len(a),'genes',a.symbol.nunique())
for c in sorted(ap.condition.unique()): print('A program',c,len(ap[ap.condition==c]),ap[ap.condition==c].symbol.nunique())
print('Stim8hr program rows/unique',len(ap[ap.condition=='Stim8hr']),ap[ap.condition=='Stim8hr'].symbol.nunique())
# count rows where A includes effect solely due to n_downstream but T1 ontarget false
stim=ap[ap.condition=='Stim8hr']
merged=stim.merge(t1.rename(columns={'target_contrast':'ensg','target_contrast_gene_name':'symbol','culture_condition':'condition'}),on=['ensg','symbol','condition'],how='left',suffixes=('','_t1'))
sole=merged[(~merged.ontarget_significant)&(merged.n_downstream_t1>0)]
print('Stim8hr A program rows with downstream>0 but ontarget_significant False',len(sole),'sample',sole[['symbol','n_downstream_t1','offtarget_flag']].head(10).to_dict('records'))
# NAB2 claims
sym='NAB2'; cond='Stim8hr'
ens=t1.loc[t1.target_contrast_gene_name==sym,'target_contrast'].iloc[0]
print('NAB2 ens',ens)
print('NAB2 T4', t4[(t4.perturbed_gene_id==ens)&(t4.culture_condition==cond)][['signif_knockdown','adj_p_value','guide_mean_expr','ntc_mean_expr']].to_dict('records'))
print('NAB2 T1', t1[(t1.target_contrast_gene_name==sym)&(t1.culture_condition==cond)].to_dict('records'))
print('NAB2 T2', t2[t2.variable==sym][['contrast','log_fc','zscore','adj_p_value']].to_dict('records'))
# T3 exact-C rows
T3=pd.read_csv(data/'cluster_autoimmune_enrichment_results.suppl_table.csv')
T3real=T3[~T3.negative_control_disease.astype(bool)].copy()
rows=[]
for _,r in T3real.iterrows():
    try: genes=ast.literal_eval(r.intersecting_genes) if isinstance(r.intersecting_genes,str) else []
    except Exception: genes=[]
    if sym in genes:
        rows.append((r.cluster,r.disease,r.gene_set,r.odds_ratio,r.p_adj_fdr))
print('NAB2 exact atopic Stim8hr T3', [x for x in rows if x[1]=='atopic eczema' and x[2]=='downstream_Stim8hr'])

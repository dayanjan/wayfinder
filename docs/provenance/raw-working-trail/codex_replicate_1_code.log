    1: """Co-occurrence + novelty scoring for the LBD proposer (fresh, new-work-only).
    2: 
    3: For each (A gene, B program, C disease) triple:
    4:   ab       = Europe PMC co-mentions, gene x program terms          (A-B bridge; per gene)
    5:   bc       = Europe PMC co-mentions, program terms x disease        (B-C bridge; per disease)
    6:   ac_lit   = Europe PMC co-mentions, gene x disease                 (A-C literature)
    7:   ac_known = Open Targets association score (gene, disease)         (A-C known; disease map)
    8:   effect   = dataset effect strength (n_downstream DE genes)        (per gene; the "not obscure
    9:                                                                       IN THE DATA" prior)
   10: 
   11: Scoring is a GATED/BALANCED objective, not a linear reward (Codex consult 2026-07-08):
   12:   GATE (eligibility): ab >= ab_gate  AND  bc >= min_bc  AND  ac_known <= tau  AND  ac_lit <= max_ac
   13:   RANK score        : min(z(log1p ab), z(log1p bc))  +  beta*z(log1p effect)
   14:                       -  w*log1p(ac_lit)  -  w2*ac_known
   15: `min(z_ab, z_bc)` stops one axis rescuing a weak other; `ab_gate` (a universe percentile)
   16: excludes genes that are "novel" only because they are understudied; the effect prior rewards
   17: "understudied in literature BUT strong in the data" -- the compelling novelty, not obscurity.
   18: """
   19: from __future__ import annotations
   20: 
   21: import math
   22: from statistics import mean, pstdev
   23: 
   24: from . import sources as S
   25: from .entity_maps import program_terms
   26: from .entities import build_a_universe, load_c
   27: 
   28: 
   29: def _zmap(values: dict) -> dict:
   30:     """z-score of log1p(value) across a dict {key: raw}. Returns {key: z}."""
   31:     logs = {k: math.log1p(max(0.0, v)) for k, v in values.items()}
   32:     m, sd = mean(logs.values()), pstdev(logs.values()) if len(logs) > 1 else 0.0
   33:     return {k: (0.0 if sd == 0 else (lv - m) / sd) for k, lv in logs.items()}
   34: 
   35: 
   36: def _percentile(sorted_vals, q):
   37:     if not sorted_vals:
   38:         return 0
   39:     i = min(len(sorted_vals) - 1, max(0, int(round(q * (len(sorted_vals) - 1)))))
   40:     return sorted_vals[i]
   41: 
   42: 
   43: def preflight_sample(n_genes: int = 20, condition: str = "Stim8hr",
   44:                      min_bc: int = 3, max_ac: int = 0, tau: float = 0.1,
   45:                      ab_gate_pct: float = 0.50, beta: float = 1.0, w: float = 1.0,
   46:                      w2: float = 3.0, program_significant: bool = True,
   47:                      rank_genes_by_effect: bool = True, extra_genes=None) -> dict:
   48:     """Run the pipeline over a bounded gene sample; return histograms + ranked survivors.
   49: 
   50:     Genes are chosen by dataset effect strength (rank_genes_by_effect) rather than
   51:     alphabetically, so the sample probes the biologically-strong corner, not the obscure one.
   52:     API cost: n_genes A-B + 12 B-C + 12 disease maps + n_genes*12 A-C-lit (all cached).
   53:     """
   54:     a = build_a_universe(condition=condition, program_significant=program_significant)
   55:     if rank_genes_by_effect:
   56:         a = a.sort_values("n_downstream", ascending=False)
   57:     genes = list(dict.fromkeys(a["symbol"].tolist()))[:n_genes]
   58:     effect = dict(zip(a["symbol"], a["n_downstream"]))
   59:     for g in (extra_genes or []):
   60:         if g not in genes:
   61:             genes.append(g)
   62:             effect.setdefault(g, 0)
   63:     diseases = load_c()
   64: 
   65:     bc = {d["disease"]: S.cooccur_count(program_terms("BC"), d["disease"]) for d in diseases}
   66:     known = {d["disease"]: S.opentargets_disease_targets(d["id"]) for d in diseases}
   67:     ab = {g: S.cooccur_count(g, program_terms("AB")) for g in genes}
   68: 
   69:     ab_gate = _percentile(sorted(ab.values()), ab_gate_pct)
   70:     z_ab = _zmap(ab)
   71:     z_bc = _zmap(bc)
   72:     z_eff = _zmap({g: effect.get(g, 0) for g in genes})
   73: 
   74:     triples = []
   75:     for g in genes:
   76:         for d in diseases:
   77:             dn = d["disease"]
   78:             ac_lit = S.cooccur_count(g, dn)
   79:             ac_known = S.opentargets_known(g, known[dn])
   80:             # GATE = real program bridge + disease footprint + NOT a curated known association.
   81:             # ac_lit is NOT in the gate (F-007): raw literature co-mention is noisy, so it only
   82:             # PENALIZES the rank -- otherwise well-studied strong regulators (which usually have
   83:             # some disease literature) are all excluded and nothing survives.
   84:             eligible = (ab[g] >= ab_gate and bc[dn] >= min_bc and ac_known <= tau)
   85:             score = (min(z_ab[g], z_bc[dn]) + beta * z_eff[g]
   86:                      - w * math.log1p(ac_lit) - w2 * ac_known)
   87:             triples.append({"gene": g, "disease": dn, "ab": ab[g], "bc": bc[dn],
   88:                             "ac_lit": ac_lit, "ac_known": round(ac_known, 4),
   89:                             "effect": int(effect.get(g, 0)),
   90:                             "pure_disjoint": bool(ac_lit <= max_ac),
   91:                             "score": round(score, 3), "eligible": bool(eligible)})
   92: 
   93:     survivors = sorted([t for t in triples if t["eligible"]],
   94:                        key=lambda t: t["score"], reverse=True)
   95:     return {
   96:         "n_genes": len(genes), "condition": condition, "n_triples": len(triples),
   97:         "gene_selection": "effect-ranked" if rank_genes_by_effect else "alphabetical",
   98:         "params": {"min_bc": min_bc, "max_ac": max_ac, "tau": tau,
   99:                    "ab_gate_pct": ab_gate_pct, "ab_gate_value": ab_gate,
  100:                    "beta": beta, "w": w, "w2": w2},
  101:         "ac_lit_zero_frac": round(sum(1 for t in triples if t["ac_lit"] == 0) / len(triples), 3),
  102:         "ac_known_below_tau_frac": round(sum(1 for t in triples if t["ac_known"] <= tau) / len(triples), 3),
  103:         "n_eligible_survivors": len(survivors),
  104:         "n_pure_disjoint_survivors": sum(1 for t in survivors if t["pure_disjoint"]),
  105:         "top_survivors": survivors[:12],
  106:         "genes": genes,
  107:     }

   95: 
   96: # ----------------------------------------------------------------------------- verdict schema
   97: @dataclass
   98: class Hop:
   99:     hop: int
  100:     name: str
  101:     status: str                       # supported | refuted | untested | flagged
  102:     claim: str
  103:     receipt: dict = field(default_factory=dict)   # the exact table values
  104:     caveats: list = field(default_factory=list)
  105: 
  106: 
  107: @dataclass
  108: class Verdict:
  109:     gene_symbol: Optional[str]
  110:     gene_ensg: Optional[str]
  111:     condition: str
  112:     overall: str                      # calibrated one-liner
  113:     gate_pass: bool
  114:     hops: list = field(default_factory=list)
  115: 
  116:     def to_dict(self):
  117:         d = asdict(self)
  118:         return d
  119: 
  120:     def summary(self) -> str:
  121:         lines = [f"REFEREE VERDICT  {self.gene_symbol or '?'} ({self.gene_ensg or '?'})  @ {self.condition}",
  122:                  f"  overall: {self.overall}"]
  123:         for h in self.hops:
  124:             lines.append(f"  HOP {h.hop} {h.name:<16} [{h.status:^9}] {h.claim}")
  125:             for k, v in h.receipt.items():
  126:                 lines.append(f"        - {k}: {v}")
  127:             for c in h.caveats:
  128:                 lines.append(f"        ! {c}")
  129:         return "\n".join(lines)
  130: 
  131: 
  132: # ----------------------------------------------------------------------------- the referee
  133: def referee(gene: str, condition: str, data: RefereeData) -> Verdict:
  134:     """Trace `gene` (SYMBOL or ENSG) at `condition` through the evidence chain."""
  135:     if condition not in CONDITIONS:

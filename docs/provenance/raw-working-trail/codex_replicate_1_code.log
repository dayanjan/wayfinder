    1: """External data-source clients for the LBD proposer (fresh, new-work-only).
    2: 
    3: Three keyless services cover v1:
    4:   - Europe PMC  : literature co-mention counts (A-B, B-C, A-C-lit bridges).
    5:   - Open Targets: the KNOWN gene-disease association set to EXCLUDE (A-C-known).
    6:   - MyGene      : gene SYMBOL -> Ensembl id / alias normalization.
    7: 
    8: `.env` keys (NCBI/OpenAlex/Semantic Scholar) are optional fallbacks/politeness and are
    9: loaded but not required for v1. Every call is cached via `_http`.
   10: """
   11: from __future__ import annotations
   12: 
   13: from . import _http
   14: 
   15: _http.load_env()
   16: 
   17: EUROPEPMC = "https://www.ebi.ac.uk/europepmc/webservices/rest/search"
   18: OPENTARGETS = "https://api.platform.opentargets.org/api/v4/graphql"
   19: MYGENE = "https://mygene.info/v3/query"
   20: 
   21: 
   22: # --- Europe PMC: co-mention counts ------------------------------------------------
   23: def _phrase(term: str) -> str:
   24:     # ALWAYS quote (incl. bare gene symbols like AAK1/IL2/JUN) so they match as tokens, not
   25:     # substrings -- unquoted symbols produced false-positive co-mentions (Codex consult
   26:     # 2026-07-08). Fielded gene-annotation queries are a future hardening.
   27:     return f'"{term}"'
   28: 
   29: 
   30: def europepmc_count(query: str) -> int:
   31:     """Total hit count for a Europe PMC query string."""
   32:     data = _http.get(EUROPEPMC, params={"query": query, "format": "json", "pageSize": 1})
   33:     return int(data.get("hitCount", 0))
   34: 
   35: 
   36: def cooccur_count(terms_a, terms_b) -> int:
   37:     """Literature co-mention count for (any of terms_a) AND (any of terms_b).
   38: 
   39:     terms_a / terms_b may be a str or list[str]; lists are OR-ed. Used for A-B, B-C,
   40:     and A-C-lit bridges. Phrases are quoted so multi-word terms match as phrases.
   41:     """
   42:     if isinstance(terms_a, str):
   43:         terms_a = [terms_a]
   44:     if isinstance(terms_b, str):
   45:         terms_b = [terms_b]
   46:     a = " OR ".join(_phrase(t) for t in terms_a)
   47:     b = " OR ".join(_phrase(t) for t in terms_b)
   48:     return europepmc_count(f"({a}) AND ({b})")
   49: 
   50: 
   51: # --- Open Targets: the known gene->disease association set (to EXCLUDE) ------------
   52: # associatedTargets page size is capped at 3000 (size>3000 errors). Rows are ordered by
   53: # score DESC, so we paginate and stop once scores fall below the novelty floor -- a gene
   54: # not in the map has effectively zero known association (the novelty signal we want).
   55: _OT_PAGE = 3000
   56: _ASSOC_QUERY = """query($id:String!,$idx:Int!,$size:Int!){
   57:   disease(efoId:$id){ id name associatedTargets(page:{index:$idx,size:$size}){
   58:     count rows{ target{ approvedSymbol } score } } } }"""
   59: 
   60: 
   61: def opentargets_disease_targets(disease_id: str, score_floor: float = 0.05,
   62:                                 max_pages: int = 5) -> dict[str, float]:
   63:     """Map approvedSymbol -> association score for a disease (disease-side, paginated).
   64: 
   65:     Use the DISEASE side: the target-side associatedDiseases(efoIds:[...]) filter returned
   66:     empty for the known GATA3 x asthma pair (verified 2026-07-08). `disease_id` is the
   67:     Open Targets/MONDO id from entity_maps (NOT EFO). Stops paginating once a page's lowest
   68:     score < score_floor (rows are score-DESC) or all rows are read.
   69:     """
   70:     out: dict[str, float] = {}
   71:     for idx in range(max_pages):
   72:         data = _http.post(OPENTARGETS, json_body={
   73:             "query": _ASSOC_QUERY,
   74:             "variables": {"id": disease_id, "idx": idx, "size": _OT_PAGE}})
   75:         dis = (data.get("data") or {}).get("disease")
   76:         if not dis:
   77:             break
   78:         at = dis["associatedTargets"]
   79:         rows = at["rows"]
   80:         for r in rows:
   81:             out[r["target"]["approvedSymbol"]] = float(r["score"])
   82:         if len(rows) < _OT_PAGE or (rows and float(rows[-1]["score"]) < score_floor):
   83:             break
   84:         if (idx + 1) * _OT_PAGE >= at["count"]:
   85:             break
   86:     return out
   87: 
   88: 
   89: def opentargets_known(gene_symbol: str, disease_targets: dict[str, float]) -> float:
   90:     """Known-association score for a gene against a prefetched disease->targets map.
   91: 
   92:     0.0 means "no known association" (a novelty signal). Callers should prefetch each
   93:     disease's map once via opentargets_disease_targets and reuse it across genes.
   94:     """
   95:     return disease_targets.get(gene_symbol, 0.0)
   96: 
   97: 
   98: # --- MyGene: symbol -> Ensembl -----------------------------------------------------
   99: def mygene_ensembl(symbol: str) -> str | None:
  100:     """Resolve a human gene SYMBOL to its primary Ensembl gene id (or None)."""
  101:     data = _http.get(MYGENE, params={"q": f"symbol:{symbol}", "species": "human",
  102:                                      "fields": "ensembl.gene", "size": 1})
  103:     hits = data.get("hits", [])
  104:     if not hits:
  105:         return None
  106:     ens = hits[0].get("ensembl")
  107:     if isinstance(ens, list):
  108:         ens = ens[0] if ens else None
  109:     return (ens or {}).get("gene") if isinstance(ens, dict) else None

import pandas as pd, ast, json, hashlib, math
from pathlib import Path
from collections import Counter
root=Path(r'C:\\Users\\wijesingheds\\Documents\\04 Fun with Coding\\2026-07-07 PyZoBot-Arbiter')
data=root/'data'; cache=data/'lbd_cache'
# entity maps, copied from file semantics to avoid importing network clients
DISEASES={
 'asthma':'MONDO_0004979', \"Crohn's disease\":'MONDO_0005011', 'ulcerative colitis':'MONDO_0005101', 'rheumatoid arthritis':'MONDO_0008383',
 'systemic lupus erythematosus':'MONDO_0007915', 'psoriasis':'MONDO_0005083', 'multiple sclerosis':'MONDO_0005301', 'type 1 diabetes mellitus':'MONDO_0005147',
 'celiac disease':'MONDO_0005130', 'ankylosing spondylitis':'MONDO_0005306', 'atopic eczema':'MONDO_0004980', \"Hashimoto's thyroiditis\":'MONDO_0007699'}
AB=['Th2 cells','T helper 2','type 2 immunity','Th2 differentiation','Th1 cells','T helper 1','type 1 immunity','Th1 differentiation','Th1/Th2 polarization','CD4 T cell polarization','T helper cell differentiation']
BC=AB+['GATA3','IL-4','IL-13','T-bet','IFN-gamma','interferon gamma']
EU='https://www.ebi.ac.uk/europepmc/webservices/rest/search'
OT='https://api.platform.opentargets.org/api/v4/graphql'
ASSOC=\"\"\"query("'$id:String!,$idx:Int!,$size:Int!){
  disease(efoId:$id){ id name associatedTargets(page:{index:$idx,size:$size}){
    count rows{ target{ approvedSymbol } score } } } }"""
def key(method,url,payload):
    blob=json.dumps({'"'m':method,'u':url,'p':payload}, sort_keys=True)
    return cache/(hashlib.sha1(blob.encode()).hexdigest()[:20]+'.json')
def phrase(t): return f'\"{t}\"'
def cooccur(a,b):
    if isinstance(a,str): a=[a]
    if isinstance(b,str): b=[b]
    q='('+' OR '.join(phrase(t) for t in a)+') AND ('+' OR '.join(phrase(t) for t in b)+')'
    p={'params':{'query':q,'format':'json','pageSize':1},'json':None}
    f=key('GET',EU,p)
    if not f.exists(): raise FileNotFoundError(f)
    return int(json.loads(f.read_text()).get('hitCount',0))
def ot_targets(did):
    out={}
    for idx in range(5):
        p={'params':None,'json':{'query':ASSOC,'variables':{'id':did,'idx':idx,'size':3000}}}
        f=key('POST',OT,p)
        if not f.exists(): raise FileNotFoundError(f)
        dat=json.loads(f.read_text())
        dis=(dat.get('data') or {}).get('disease')
        if not dis: break
        at=dis['associatedTargets']; rows=at['rows']
        for r in rows: out[r['target']['approvedSymbol']]=float(r['score'])
        if len(rows)<3000 or (rows and float(rows[-1]['score'])<0.05): break
        if (idx+1)*3000 >= at['count']: break
    return out
# A universe as code
t4=pd.read_csv(data/'guide_kd_efficiency.suppl_table.csv', usecols=['perturbed_gene_id','culture_condition','signif_knockdown'])
t1=pd.read_csv(data/'DE_stats.suppl_table.csv', usecols=['target_contrast','target_contrast_gene_name','culture_condition','ontarget_significant','n_downstream','offtarget_flag'])
t2=pd.read_csv(data/'Th2_Th1_polarization_signature_DE_results_full.suppl_table.csv')
t4.signif_knockdown=t4.signif_knockdown.astype(str).str.lower().eq('true')
t1.ontarget_significant=t1.ontarget_significant.astype(str).str.lower().eq('true')
t1.offtarget_flag=t1.offtarget_flag.astype(str).str.lower().eq('true')
t1.n_downstream=pd.to_numeric(t1.n_downstream).fillna(0)
g=t4.dropna(subset=['perturbed_gene_id']).groupby(['perturbed_gene_id','culture_condition']).signif_knockdown.any().reset_index()
g=g[g.signif_knockdown].rename(columns={'perturbed_gene_id':'ensg','culture_condition':'condition'})
e=t1[t1.ontarget_significant | (t1.n_downstream>0)].rename(columns={'target_contrast':'ensg','target_contrast_gene_name':'symbol','culture_condition':'condition'})
e=e.groupby(['ensg','symbol','condition']).n_downstream.max().reset_index()
a=g.merge(e,on=['ensg','condition'])[['ensg','symbol','condition','n_downstream']].drop_duplicates()
prog=set(t2.loc[pd.to_numeric(t2.adj_p_value, errors='coerce')<0.05,'variable'])
a=a[(a.condition=='Stim8hr') & a.symbol.isin(prog)]
genes=list(dict.fromkeys(a.symbol.tolist()))
effect=dict(zip(a.symbol,a.n_downstream))
ab={gene:cooccur(gene,AB) for gene in genes}
bc={dn:cooccur(BC,dn) for dn in DISEASES}
known={dn:ot_targets(did) for dn,did in DISEASES.items()}
ab_gate=sorted(ab.values())[int(round(0.50*(len(ab)-1)))]
elig=[(gene,dn) for gene in genes for dn in DISEASES if ab[gene]>=ab_gate and bc[dn]>=3 and known[dn].get(gene,0.0)<=0.1]
print('a_genes',len(genes),'ab_gate',ab_gate,'eligible',len(elig))
# exact-C chain classes from raw local tables
t3=pd.read_csv(data/'cluster_autoimmune_enrichment_results.suppl_table.csv')
expl=[]
for _,r in t3[~t3.negative_control_disease.astype(bool)].iterrows():
    try: gl=ast.literal_eval(r.intersecting_genes) if isinstance(r.intersecting_genes,str) else []
    except Exception: gl=[]
    for gene in gl: expl.append((gene,r.disease,r.gene_set,float(r.p_adj_fdr)))
ex=pd.DataFrame(expl, columns=['gene','disease','gene_set','p_adj_fdr'])
classes=Counter()
for gene,dn in elig:
    t1r=t1[(t1.target_contrast_gene_name==gene)&(t1.culture_condition=='Stim8hr')].iloc[0]
    disease=bool(len(ex[(ex.gene==gene)&(ex.disease==dn)&(ex.gene_set=='downstream_Stim8hr')&(ex.p_adj_fdr<0.05)]))
    if not disease: classes['refuted_for_c']+=1
    elif not bool(t1r.ontarget_significant): classes['refuted_effect']+=1
    elif int(t1r.n_downstream)==0: classes['supported_weak']+=1
    elif bool(t1r.offtarget_flag): classes['supported_flagged']+=1
    else: classes['supported']+=1
print('classes',dict(classes),'disease_C_supported_total',sum(classes[k] for k in ['supported','supported_weak','supported_flagged']),'clean',classes['supported'])

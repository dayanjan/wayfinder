   79:                              "p_adj_fdr": _REF._fmt(top.p_adj_fdr),
   80:                              "n_significant_clusters": int(len(sig))}),
   81:                 "supported")
   82:     best = sub_c.sort_values("p_adj_fdr").iloc[0]
